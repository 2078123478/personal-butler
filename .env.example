PORT=3000
LOG_LEVEL=info
DATA_DIR=data
API_SECRET=replace-with-long-random-token
DEMO_PUBLIC=false
ENABLED_STRATEGIES=dex-arbitrage
ENGINE_INTERVAL_MS=5000
QUOTE_STALE_MS=1000
WS_ENABLED=false
WS_URL=
WS_RECONNECT_MS=2000
PAIR=ETH/USDC
DEX_A=okx-dex-a
DEX_B=okx-dex-b
START_MODE=paper
# SECURITY RISK: true means engine can run in live mode with real execution.
LIVE_ENABLED=false
# SECURITY RISK: true allows automatic promotion from paper to live when gate passes.
AUTO_PROMOTE_TO_LIVE=false
PAPER_START_BALANCE_USD=10000
LIVE_BALANCE_USD=3000
MIN_NET_EDGE_BPS_PAPER=45
MIN_NET_EDGE_BPS_LIVE=60
MAX_TRADE_PCT_BALANCE=0.03
MAX_DAILY_LOSS_PCT=0.015
MAX_CONSECUTIVE_FAILURES=3
SLIPPAGE_BPS=12
TAKER_FEE_BPS=20
GAS_USD_DEFAULT=1.25
MEV_PENALTY_BPS=5
LIQUIDITY_USD_DEFAULT=250000
VOLATILITY_DEFAULT=0.02
AVG_LATENCY_MS_DEFAULT=250
EVAL_NOTIONAL_USD_DEFAULT=1000
DISCOVERY_DEFAULT_DURATION_MINUTES=30
DISCOVERY_DEFAULT_SAMPLE_INTERVAL_SEC=5
DISCOVERY_DEFAULT_TOPN=20
DISCOVERY_LOOKBACK_SAMPLES=60
DISCOVERY_Z_ENTER=2
DISCOVERY_VOL_RATIO_MIN=1.8
DISCOVERY_MIN_SPREAD_BPS=35
DISCOVERY_NOTIONAL_USD=1000

# ============================================
# Network Profile — 选择你的启动路径
# ============================================
# 二选一：
#   - xlayer-recommended: X Layer 推荐路径（默认），自动配置 chain 196 + 推荐 RPC + poll 模式 + hmac auth
#   - evm-custom: 自定义 EVM 链，需要手动指定 ONCHAINOS_CHAIN_INDEX 和 COMM_RPC_URL
NETWORK_PROFILE_ID=xlayer-recommended

# --- X Layer Recommended 路径 ---
# 当 NETWORK_PROFILE_ID=xlayer-recommended 时，以下配置会自动使用默认值：
#   ONCHAINOS_CHAIN_INDEX=196
#   COMM_CHAIN_ID=196
#   COMM_RPC_URL=https://rpc.xlayer.tech (备用：https://xlayerrpc.okx.com)
#   COMM_LISTENER_MODE=poll
#   ONCHAINOS_AUTH_MODE=hmac
# 你只需要填写 OnchainOS 凭证即可启动推荐路径。

# --- EVM Custom 路径 ---
# 当 NETWORK_PROFILE_ID=evm-custom 时，必须显式指定：
# ONCHAINOS_CHAIN_INDEX=<你的链 index>
# COMM_CHAIN_ID=<你的链 ID>
# COMM_RPC_URL=<你的 RPC URL>
# COMM_LISTENER_MODE=poll

# ============================================
# OnchainOS 凭证（两条路径都需要）
# ============================================
ONCHAINOS_API_BASE=
ONCHAINOS_API_KEY=
ONCHAINOS_API_SECRET=
ONCHAINOS_PASSPHRASE=
ONCHAINOS_PROJECT_ID=
# auth mode 会被 profile 默认覆盖（xlayer-recommended 用 hmac），但可手动覆盖
ONCHAINOS_AUTH_MODE=bearer
ONCHAINOS_API_KEY_HEADER=X-API-Key
# chain index 会被 profile 默认覆盖（xlayer-recommended 用 196），但可手动覆盖
ONCHAINOS_CHAIN_INDEX=196
ONCHAINOS_REQUIRE_SIMULATE=true
ONCHAINOS_ENABLE_COMPAT_FALLBACK=true
ONCHAINOS_TOKEN_CACHE_TTL_SECONDS=600
ONCHAINOS_TOKEN_PROFILE_PATH=/api/v6/market/token/profile/current

# ============================================
# Agent-Comm v0.1 (single-chain, poll-only)
# ============================================
# 当 NETWORK_PROFILE_ID=xlayer-recommended 时，COMM_CHAIN_ID 和 COMM_LISTENER_MODE 会被自动设置
COMM_ENABLED=false
COMM_CHAIN_ID=196
COMM_RPC_URL=
# supported values: disabled | poll
COMM_LISTENER_MODE=disabled
COMM_POLL_INTERVAL_MS=5000
COMM_WALLET_ALIAS=agent-comm
COMM_RELAY_URL=
COMM_RELAY_TIMEOUT_MS=10000
# supported values: direct | relay
COMM_SUBMIT_MODE=direct
# when COMM_ENABLED=true, VAULT_MASTER_PASSWORD must be provided at startup
# optional placeholders (not in v0.1 acceptance scope)
COMM_PAYMASTER_URL=
# supported values: disabled | observe | enforce
X402_MODE=disabled

# ============================================
# Vault & Hooks
# ============================================
# VAULT_MASTER_PASSWORD 在启用 agent-comm 时必须提供
# optional values for scripts/onchainos-live-smoke.sh
ALPHAOS_PROBE_PAIR=ETH/USDC
ALPHAOS_PROBE_CHAIN_INDEX=196
ALPHAOS_PROBE_NOTIONAL_USD=25
ALPHAOS_PROBE_WALLET=0x1111111111111111111111111111111111111111
OPENCLAW_HOOK_URL=http://127.0.0.1:18789/hooks/wake
OPENCLAW_HOOK_TOKEN=
STRATEGY_PROFILE_DEFAULTS={"dex-arbitrage":{"variant":"A","notionalMultiplier":1}}

# ============================================
# Living Assistant Delivery (Demo)
# ============================================
# Telegram (required for --send, optional fallback for --call)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# TTS (required for --send, optional for --call)
TTS_BASE_URL=
TTS_API_KEY=
TTS_MODEL=
TTS_VOICE=

# Twilio voice call (recommended for --call, no template approval)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_TO_NUMBER=
# optional alias for destination number
# TWILIO_DEFAULT_TO_NUMBER=

# Aliyun voice call (optional fallback for --call, template code required)
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_CALLED_SHOW_NUMBER=
ALIYUN_CALLED_NUMBER=
ALIYUN_TTS_CODE=
ALIYUN_ENDPOINT=
